// ============================================================================
//  arduino_secrets.h  —  TEMPLATE
// ============================================================================
//  Copy this file to arduino_secrets.h and fill in your own values.
//  arduino_secrets.h is listed in .gitignore and must NEVER be committed.
// ============================================================================

// WiFi credentials
#define SECRET_SSID   "YourWiFiSSID"
#define SECRET_PASS   "YourWiFiPassword"

// Optional: hostname that appears in the browser tab and router DHCP table.
// Must be a valid DNS label: letters, digits and hyphens only (no spaces).
#define SECRET_HOST   "envlogger"

// radmon.org credentials  (https://radmon.org)
// Leave blank ("") to disable Radmon uploads at compile time.
#define SECRET_RAD_USER  "your_radmon_username"
#define SECRET_RAD_PASS  "your_radmon_password"

// uRADMonitor credentials  (https://www.uradmonitor.com)
// Leave blank ("") to disable uRADMonitor uploads at compile time.
#define SECRET_UR_USER   "your_uradmonitor_user_id"       // numeric user ID
#define SECRET_UR_KEY    "your_uradmonitor_api_key"       // hex API key
#define SECRET_UR_DEV    "your_uradmonitor_device_id"     // numeric device ID
